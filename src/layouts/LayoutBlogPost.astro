---
import Layout from "./Layout.astro";
import { formatDate } from "@/lib/helpers";
import TableOfContents from "@/components/blog/TableOfContents.astro";
import Prose from "@/components/Prose.astro";
import { ArrowLeftIcon } from "@phosphor-icons/react";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  minutesRead?: string;
  lastModified?: string;
  headings?: Heading[];
}

const { title, description, pubDate, minutesRead, lastModified, headings = [] } = Astro.props;

const lastModifiedFormatted = lastModified
  ? dayjs(lastModified).utc().format("MMM D, YYYY")
  : null;
---

<Layout title={title} description={description}>
  <main class="mx-auto w-full max-w-5xl min-h-screen p-8">
    <a
      href="/blog"
      class="mb-10 inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <ArrowLeftIcon size={16} aria-hidden="true" />
      Back to blog
    </a>

    <div class="blog-post-grid">
      <div>
        <div class="my-10">
          <h1 class="text-4xl font-bold leading-tight tracking-tight">{title}</h1>
          <div class="mt-4 flex items-center gap-3 text-sm text-muted-foreground">
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            {minutesRead ? <><span aria-hidden="true">·</span><span>{minutesRead}</span></> : null}
            {lastModifiedFormatted ? <><span aria-hidden="true">·</span><span>Updated {lastModifiedFormatted}</span></> : null}
          </div>
        </div>

        <Prose class="dark:prose-invert">
          <slot />
        </Prose>
      </div>

      {
        headings.filter((h) => h.depth === 2 || h.depth === 3).length > 0 ? (
          <aside class="toc-aside">
            <div class="toc-scroll-wrap">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        ) : null
      }
    </div>
  </main>
</Layout>

<style>
  .toc-aside {
    display: none;
  }

  @media (min-width: 1024px) {
    .blog-post-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 220px;
      gap: 3rem;
      align-items: start;
    }

    .toc-aside {
      display: block;
      position: sticky;
      top: 1.5rem;
      align-self: start;
    }

    .toc-scroll-wrap {
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
      padding-right: 0.25rem;
    }
  }

</style>


