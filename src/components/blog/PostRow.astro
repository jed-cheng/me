---
import { formatDate } from "@/lib/helpers";

interface Props {
  title: string;
  date: Date;
  slug: string;
  description?: string;
}

const { title, date, slug, description } = Astro.props;
---

<li class="list-none w-full">
  <a
    href={`/blog/${slug}`}
    class="group relative flex flex-col gap-1.5 rounded-xl border border-border px-5 py-4 transition-all duration-200 hover:border-foreground/20 hover:bg-card"
  >
    <div class="flex items-start justify-between gap-4">
      <span class="font-medium text-foreground transition-colors group-hover:text-primary">
        {title}
      </span>
      <time
        class="shrink-0 text-xs tabular-nums text-muted-foreground mt-0.5"
        datetime={date.toISOString()}
      >
        {formatDate(date)}
      </time>
    </div>
    {description ? (
      <p class="text-sm text-muted-foreground/80 line-clamp-2 leading-relaxed">{description}</p>
    ) : null}
  </a>
</li>
