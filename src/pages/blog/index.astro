---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostRow from "@/components/blog/PostRow.astro";
import { SITE } from "@/site-config";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title={`Blog · ${SITE.author.fullName}`}
  description="Articles, tutorials, and thoughts on software development."
>
  <main class="mx-auto w-full max-w-3xl min-h-screen p-8">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1 rounded-lg border border-border bg-card px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground"
    >
      ← Back
    </a>

    <h1 class="mb-2 text-4xl font-bold">Blog</h1>
    <p class="mb-8 text-muted-foreground">
      {posts.length} post{posts.length !== 1 ? "s" : ""} — thoughts, tutorials, and notes.
    </p>

    <ul class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <PostRow
            date={post.data.pubDate}
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
          />
        ))
      }
    </ul>
  </main>
</Layout>
