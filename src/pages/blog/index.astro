---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostRow from "@/components/blog/PostRow.astro";
import { SITE } from "@/site-config";
import { ArrowLeftIcon } from "@phosphor-icons/react";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title={`Blog · ${SITE.author.fullName}`}
  description="Articles, tutorials, and thoughts on software development."
>
  <main class="mx-auto w-full max-w-3xl min-h-screen px-6 py-12">
    <a
      href="/"
      class="mb-10 inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <ArrowLeftIcon size={16} aria-hidden="true" />
       Back
    </a>

    <header class="mb-10">
      <h1 class="text-5xl font-bold tracking-tight">Blog</h1>
      <p class="mt-3 text-muted-foreground">
        {posts.length} {posts.length !== 1 ? "posts" : "post"} — thoughts, tutorials, and notes.
      </p>
    </header>

    <ul class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <PostRow
            date={post.data.pubDate}
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
          />
        ))
      }
    </ul>
  </main>
</Layout>

