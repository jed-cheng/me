---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/site-config";

const projects = SITE.projects;
---

<Layout
  title={`Projects · ${SITE.author.fullName}`}
  description="A selection of projects I've built."
>
  <main class="mx-auto w-full max-w-3xl min-h-screen p-8">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1 rounded-lg border border-border bg-card px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground"
    >
      ← Back
    </a>

    <h1 class="mb-2 text-4xl font-bold">Projects</h1>
    <p class="mb-8 text-muted-foreground">Things I've built and shipped.</p>

    <ul class="flex flex-col gap-4">
      {
        projects.map((project) => (
          <li class="group rounded-xl border border-border bg-card p-5 transition-all hover:border-primary/50 hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <div class="flex flex-col gap-2">
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-lg font-semibold text-foreground transition-colors group-hover:text-primary"
                >
                  {project.title} ↗
                </a>
                <p class="text-sm text-muted-foreground">{project.description}</p>
                <div class="flex flex-wrap gap-1.5 pt-1">
                  {project.tech.map((t) => (
                    <span class="rounded-full border border-border bg-muted px-2.5 py-0.5 text-xs text-muted-foreground">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
