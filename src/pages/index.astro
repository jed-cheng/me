---
import Layout from "../layouts/Layout.astro";
import IntroCard from "@/components/cards/IntroCard";
import AboutCard from "@/components/cards/AboutCard";
import ContactCard from "@/components/cards/ContactCard";
import TimeZoneCard from "@/components/cards/TimeZoneCard";
import NowCard from "@/components/cards/NowCard";
import ThemeToggleCard from "@/components/cards/ThemeToggleCard";
import { BentoGrid, BentoGridItem } from "@/components/ui/bento-grid";
---

<Layout>
  <main class="mx-auto w-full max-w-6xl p-4 lg:h-screen lg:max-h-[800px]">
    <BentoGrid>
    <!-- Row 1-4: Intro (3 wide) + About (1 wide, 6 tall) -->
    <IntroCard client:load />
    <AboutCard client:load />

    <!-- Row 4-6: Contact (1 wide, 4 tall) + Timezone (1 wide, 2 tall) -->
    <ContactCard client:load />
    <TimeZoneCard client:load />

    <!-- Row 6-7: Now (1 wide) + ThemeToggle (1 wide) -->
    <NowCard client:load />
    <ThemeToggleCard client:load />

    <!-- Row 7-8: Link cards — customise href/title to suit you -->
    <BentoGridItem
      href="/blog"
      title="Blog"
      colSpan="col-span-1"
      rowSpan="lg:row-span-1"
      client:load
    >
      <p class="text-sm text-muted-foreground">Read my writing →</p>
    </BentoGridItem>

    <BentoGridItem
      href="/projects"
      title="Projects"
      colSpan="col-span-1"
      rowSpan="lg:row-span-1"
      client:load
    >
      <p class="text-sm text-muted-foreground">See what I've built →</p>
    </BentoGridItem>

    <!-- Footer card -->
    <BentoGridItem
      colSpan="col-span-1 md:col-span-2"
      rowSpan="lg:row-span-1"
      client:load
    >
      <p class="text-xs text-muted-foreground">
        © {new Date().getFullYear()} · Built with
        <a href="https://astro.build" target="_blank" class="underline underline-offset-2">Astro</a>,
        <a href="https://react.dev" target="_blank" class="underline underline-offset-2">React</a> &amp;
        <a href="https://ui.shadcn.com" target="_blank" class="underline underline-offset-2">shadcn/ui</a>.
      </p>
    </BentoGridItem>
    </BentoGrid>
  </main>
</Layout>
